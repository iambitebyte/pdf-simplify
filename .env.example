# Copy this file to .env and fill in your API keys

# OpenAI API Key
PDF_SUMMARY_API_KEY=your_openai_api_key_here

# OpenAI Base URL (for custom endpoints or local models)
# Example: PDF_SUMMARY_BASE_URL=http://localhost:8000/v1
# PDF_SUMMARY_BASE_URL=your_base_url_here

# Anthropic API Key (if using Anthropic)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM Provider (openai, anthropic)
PDF_SUMMARY_PROVIDER=openai

# LLM Model
PDF_SUMMARY_LLM_MODEL=gpt-4

# Summary Level (detailed, concise, minimal)
PDF_SUMMARY_SUMMARY_LEVEL=detailed

# Output Format (markdown, json, html)
PDF_SUMMARY_OUTPUT_FORMAT=markdown
